<?xml version="1.0" encoding="utf-8"?>
<ExtensionPackages Version="1.0.0.0" Compression="none">
<ExtensionPackage>
    <Name>KdExtsScript</Name>
    <Version>$#Engine_version#$</Version>
    <MinDebuggerSupported>10.0.16361.1000</MinDebuggerSupported>
    <Description>Adds various functionality to KdExts via JavaScript</Description>
    <Components>
        <ScriptComponent Name="KdExtsScript" Type="Engine" File="winext\KdExtsScript\KdExtsScript.js" FilePathKind="RepositoryRelative">
            <LoadTriggers>
                <TriggerSet>
                    <OSTrigger Name="Windows" />
                    <TargetTrigger Type="Kernel" />
                </TriggerSet>
            </LoadTriggers>
            <ObjectExtensionList>
                <NamedExtension Name="Debugger.Models.Process" />
                <NamedExtension Name="Debugger.Models.Session.Devices.PnPDevices.DeviceNode" />
                <NamedExtension Name="Debugger.Models.Session.Devices.PnPDevices.DeviceTree" />
            </ObjectExtensionList>
            <Views>
                <View Query="@$cursession.Devices.PnPDevices.DeviceTree" Name="Device Tree" ViewKind="Tree" Group="Devices" IsPrimary="true" LargeIconData="" SmallIconData="" />
                <View Query="@$cursession.Devices.PnPDevices.DeviceTree.Flatten(n => n.Children)" Name="Device List" ViewKind="Grid" Group="Devices" LargeIconData="" SmallIconData="" />
                <View Query="@$curprocess.Io.Handles" Name="Handles" ViewKind="Grid" LargeIconData="" SmallIconData="" />
            </Views>
        </ScriptComponent>
    </Components>
</ExtensionPackage>
</ExtensionPackages>
